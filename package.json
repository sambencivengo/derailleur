{
  "name": "derailleur",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "docker:db": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:test:up": "docker compose -f docker/docker-compose.yml up -d db_test",
    "docker:test:down": "docker compose -f docker/docker-compose.yml stop db_test",
    "docker:container": "docker exec -it $cid psql -U user derailleur",
    "dev": "pnpm run prisma:seed & next dev",
    "dev-lint": "next lint && next dev",
    "build": "pnpm exec prisma generate && pnpm run migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "test:migrate": "pnpm exec dotenv -e .env.test -- prisma migrate deploy",
    "test": "docker compose -f docker/docker-compose.yml up -d db_test && pnpm run test:migrate && pnpm exec dotenv -e .env.test -- vitest run",
    "test:watch": "docker compose -f docker/docker-compose.yml up -d db_test && pnpm run test:migrate && pnpm exec dotenv -e .env.test -- vitest watch",
    "migrate": "pnpm exec prisma migrate deploy",
    "migrate:create": "pnpm exec prisma migrate dev --name",
    "prisma:client generate": "pnpm exec prisma generate",
    "prisma:studio": "pnpm exec prisma studio",
    "prisma:seed": "pnpm exec prisma db seed"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.629.0",
    "@hookform/resolvers": "^3.3.2",
    "@prisma/client": "^5.18.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/postgres": "^0.9.0",
    "argon2": "^0.31.1",
    "axios": "^1.6.2",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "dotenv-cli": "^7.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.2",
    "express": "^4.18.2",
    "lucide-react": "^1.7.0",
    "moment": "^2.29.4",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.48.2",
    "react-photoswipe-gallery": "^3.0.2",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.5.0",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.4",
    "assert": "^2.1.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.31",
    "prisma": "^5.18.0",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^2.0.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
